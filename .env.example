# ============================================================
# Dobaara — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# ----------------------------
# Supabase (required)
# Found in: Supabase Dashboard → Project → Settings → API
# ----------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ----------------------------
# Stripe (required for payments — not yet wired in frontend)
# Found in: Stripe Dashboard → Developers → API Keys
# ----------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# ----------------------------
# Resend (transactional email)
# Found in: resend.com → API Keys
# ----------------------------
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=noreply@dobaara.co
RESEND_NOTIFICATION_EMAIL=info@dobaara.co

# ----------------------------
# Supabase service role key (for edge functions only — never expose to browser)
# Found in: Supabase Dashboard → Project → Settings → API → service_role
# ----------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------
# App config
# ----------------------------
VITE_APP_URL=http://localhost:8080
